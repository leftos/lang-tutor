# Dependencies
node_modules/

# Build output
dist/

# .NET build artifacts (wgc-capture and any future C# tools)
tools/*/bin/
tools/*/obj/

# Generated static assets — rebuilt by scripts/copy-html-to-image.mjs on
# postinstall / predev / prebuild from node_modules/html-to-image.
public/lang-tutor-assets/

# Web-course workspace (created on demand, owned by the dev/prod server)
projects/

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# Logs and temp
.tmp/
.local/
*.log
npm-debug.log*
pnpm-debug.log*

# Playwright MCP server artifacts (snapshots, console logs from browser
# automation). Generated under the project root by the playwright tool.
.playwright-mcp/

# Editor / OS
.vscode/
.idea/
.claude/settings.local.json
.claude/worktrees/
*.swp
.DS_Store
Thumbs.db
