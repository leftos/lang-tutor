# Optional production/runtime settings.
# Provider API keys are entered in the browser UI and are not stored here.
NODE_ENV=production
PORT=3000
LANG_TUTOR_BASE_PATH=/
LANG_TUTOR_REQUIRE_AUTH=false
LANG_TUTOR_SECURE_COOKIES=false
LANG_TUTOR_DB_FILE=.local/account.sqlite
LANG_TUTOR_RUN_ROOT=.tmp/runs
LANG_TUTOR_TOOLCHAIN_IMAGE=lang-tutor-toolchains:latest
